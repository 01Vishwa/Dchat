{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "functions": {
    "src/app/api/parse/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/generate/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/export/route.ts": {
      "maxDuration": 60,
      "memory": 512
    }
  },
  "regions": ["iad1"]
}
